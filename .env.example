# Copy this file to ".env" and fill in your real values from the Supabase
# dashboard (Project Settings → API). The ".env" file is git-ignored so your
# keys never get committed.
#
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
